<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RemoteStuff.ViewModels"
        xmlns:m="using:RemoteStuff.Models"
        x:Class="RemoteStuff.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource AppSurfaceBrush}"
        Title="Preferences">

    <StackPanel Margin="20" Spacing="14">
        <TextBlock Text="Preferences" FontSize="20" FontWeight="Bold" />

        <StackPanel Spacing="8">
            <TextBlock Text="General" FontWeight="Bold" Foreground="{DynamicResource AppSecondaryTextBrush}" />
            <CheckBox Content="Resume last session at startup" IsChecked="{Binding ResumeLastSession}" />
            <CheckBox Content="Start at login" IsChecked="{Binding StartAtLogin}" />
            <CheckBox Content="Menu-bar only (hide Dock icon)" IsChecked="{Binding MenuBarOnly}" />
            <CheckBox Content="Confirm before closing a running session" IsChecked="{Binding ConfirmBeforeClosing}" />
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock Text="Appearance" FontWeight="Bold" Foreground="{DynamicResource AppSecondaryTextBrush}" />
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="Theme" VerticalAlignment="Center" />
                <ComboBox ItemsSource="{Binding Themes}" SelectedItem="{Binding AppTheme, Mode=TwoWay}"
                          Width="140" />
            </StackPanel>
        </StackPanel>

        <StackPanel Spacing="8">
            <TextBlock Text="Behaviour" FontWeight="Bold" Foreground="{DynamicResource AppSecondaryTextBrush}" />
            <CheckBox Content="Right-click a profile connects immediately" IsChecked="{Binding RightClickConnects}" />
            <CheckBox Content="Automatically check for updates" IsChecked="{Binding AutoCheckUpdates}" />
        </StackPanel>

        <StackPanel Spacing="8">
            <TextBlock Text="Terminal" FontWeight="Bold" Foreground="{DynamicResource AppSecondaryTextBrush}" />
            <Grid ColumnDefinitions="*,120">
                <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,12,0">
                    <TextBlock Text="Default theme for local terminals"
                               Foreground="{DynamicResource AppSecondaryTextBrush}" />
                    <ComboBox ItemsSource="{Binding TerminalThemes}"
                              SelectedItem="{Binding DefaultTerminalTheme, Mode=TwoWay}"
                              HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="m:TerminalTheme">
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Text="Font size" Foreground="{DynamicResource AppSecondaryTextBrush}" />
                    <NumericUpDown Value="{Binding DefaultTerminalFontSize}" Minimum="8" Maximum="36" Increment="1" />
                </StackPanel>
            </Grid>
            <TextBlock Text="Applied to new local shells. Each saved profile keeps its own theme and size."
                       FontSize="11" TextWrapping="Wrap"
                       Foreground="{DynamicResource AppSecondaryTextBrush}" />
        </StackPanel>

        <Border Height="1" Background="{DynamicResource AppSecondaryTextBrush}" Opacity="0.15" Margin="0,4" />
        <TextBlock Text="{Binding AppVersion}" FontSize="11"
                   Foreground="{DynamicResource AppSecondaryTextBrush}" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
            <Button Content="Cancel" Click="OnCancel" Padding="16,6" />
            <Button Content="Save" Click="OnSave" Padding="16,6" Background="#0E639C" Foreground="White" />
        </StackPanel>
    </StackPanel>
</Window>

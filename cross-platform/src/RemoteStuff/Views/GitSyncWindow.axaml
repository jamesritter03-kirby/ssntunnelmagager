<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RemoteStuff.ViewModels"
        x:Class="RemoteStuff.Views.GitSyncWindow"
        x:DataType="vm:GitSyncViewModel"
        Width="640" Height="560"
        MinWidth="520" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppSurfaceBrush}"
        Title="Sync Profiles with Git">

    <DockPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top" Padding="14,10"
                Background="{DynamicResource AppChromeBrush}"
                BorderBrush="{DynamicResource AppDividerBrush}" BorderThickness="0,0,0,1">
            <StackPanel Spacing="2">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="🔃" FontSize="15" VerticalAlignment="Center" />
                    <TextBlock Text="Sync Profiles with Git" FontWeight="Bold" FontSize="15"
                               Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource AppSecondaryTextBrush}"
                           Text="Share your profiles.json across machines through a Git repository. Push saves and uploads your current profiles; Pull downloads them and replaces your local profiles." />
            </StackPanel>
        </Border>

        <!-- Config + actions -->
        <Border DockPanel.Dock="Top" Padding="14,12">
            <StackPanel Spacing="10">
                <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto" >
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Remote URL" VerticalAlignment="Center"
                               Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" />
                    <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,6"
                             Text="{Binding RemoteUrl}"
                             Watermark="git@github.com:user/remote-profiles.git (optional)" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Branch" VerticalAlignment="Center"
                               Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" />
                    <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,6"
                             Text="{Binding Branch}" Watermark="main" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Commit message" VerticalAlignment="Center"
                               Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" />
                    <TextBox Grid.Row="2" Grid.Column="1"
                             Text="{Binding CommitMessage}" Watermark="Optional — used when pushing" />
                </Grid>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="⬇ Pull (import)" Command="{Binding PullCommand}" />
                    <Button Content="⬆ Push (share)" Classes="accent" Command="{Binding PushCommand}" />
                    <Button Content="Init / Clone" Command="{Binding InitOrCloneCommand}" />
                    <Button Content="Status" Command="{Binding StatusCommand}" />
                    <TextBlock Text="Working…" IsVisible="{Binding IsBusy}" VerticalAlignment="Center"
                               Foreground="{DynamicResource AppSecondaryTextBrush}" FontSize="12" />
                </StackPanel>

                <TextBlock Text="{Binding RepoPath, StringFormat='Local working copy: {0}'}"
                           FontSize="11" Foreground="{DynamicResource AppMutedTextBrush}"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Border>

        <!-- Log -->
        <Border Margin="14,0,14,14" Padding="1"
                Background="{DynamicResource AppInsetBrush}"
                BorderBrush="{DynamicResource AppDividerBrush}" BorderThickness="1" CornerRadius="6">
            <TextBox Text="{Binding Log}" IsReadOnly="True" AcceptsReturn="True"
                     TextWrapping="NoWrap" FontFamily="monospace" FontSize="12"
                     Background="Transparent" BorderThickness="0"
                     VerticalContentAlignment="Top"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto" />
        </Border>
    </DockPanel>
</Window>

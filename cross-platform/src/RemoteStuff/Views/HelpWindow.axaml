<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:m="using:RemoteStuff.Models"
        x:Class="RemoteStuff.Views.HelpWindow"
        Width="820" Height="580"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppSurfaceBrush}"
        Title="Remote Stuff CP Help">

    <Grid ColumnDefinitions="240,*">

        <!-- Topic list -->
        <DockPanel Grid.Column="0" Background="{DynamicResource AppChromeBrush}">
            <Border DockPanel.Dock="Top" Padding="14,12" Background="{DynamicResource AppInsetBrush}" BorderBrush="{DynamicResource AppDividerBrush}" BorderThickness="0,0,0,1">
                <StackPanel Spacing="2">
                    <TextBlock Text="Remote Stuff CP" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource AppTextBrush}" />
                    <TextBlock x:Name="VersionText" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" />
                </StackPanel>
            </Border>
            <ListBox x:Name="TopicList" Background="Transparent" BorderThickness="0" Padding="4">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="m:HelpArticle">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding Icon}" FontSize="14" Width="20" />
                            <TextBlock Text="{Binding Title}" VerticalAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- Article content -->
        <ScrollViewer Grid.Column="1">
            <StackPanel x:Name="ContentPanel" Spacing="10" MaxWidth="640" HorizontalAlignment="Left" Margin="24,20" />
        </ScrollViewer>
    </Grid>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RemoteStuff.ViewModels"
        x:Class="RemoteStuff.Views.KnownHostsWindow"
        x:DataType="vm:KnownHostsViewModel"
        Width="560" Height="520" MinWidth="420" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppSurfaceBrush}"
        Title="Manage Known Hosts">

    <Grid RowDefinitions="Auto,*,Auto" Margin="16">
        <StackPanel Grid.Row="0" Spacing="10">
            <TextBlock Text="Known hosts" FontSize="20" FontWeight="Bold" />
            <TextBlock Text="Remove a stale entry to clear the “host identification has changed” warning after a server rebuild."
                       Foreground="{DynamicResource AppSecondaryTextBrush}" TextWrapping="Wrap" FontSize="12" />
            <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0" Text="{Binding Filter}" Watermark="Filter by host or key type" />
                <Button Grid.Column="1" Content="Reload" Margin="8,0,0,0" Command="{Binding ReloadCommand}" />
            </Grid>
        </StackPanel>

        <Border Grid.Row="1" Background="{DynamicResource AppInsetBrush}" BorderBrush="{DynamicResource AppDividerBrush}" BorderThickness="1"
                CornerRadius="6" Margin="0,12" Padding="4">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Rows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:KnownHostRowViewModel">
                            <Border Background="{DynamicResource AppPillBrush}" CornerRadius="4" Padding="10" Margin="4,3">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="{Binding HostLabel}" FontWeight="SemiBold"
                                                   FontFamily="Menlo, Consolas, monospace" />
                                        <TextBlock Text="{Binding KeyType}" Foreground="#999" FontSize="11" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Remove" VerticalAlignment="Center"
                                            Command="{Binding $parent[ItemsControl].((vm:KnownHostsViewModel)DataContext).RemoveCommand}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <TextBlock Grid.Row="2" Text="{Binding StatusText}" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" />
    </Grid>
</Window>

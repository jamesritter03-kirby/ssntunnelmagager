<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RemoteStuff.ViewModels"
        xmlns:ctl="using:RemoteStuff.Views.Controls"
        x:Class="RemoteStuff.Views.WorkspaceStatsWindow"
        x:DataType="vm:WorkspaceStatsViewModel"
        Width="640" Height="660"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppSurfaceBrush}"
        Title="Connection Health">

    <DockPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top" Padding="14,10"
                Background="{DynamicResource AppChromeBrush}"
                BorderBrush="{DynamicResource AppDividerBrush}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="📶" FontSize="15" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding WorkspaceName}" FontWeight="Bold" FontSize="15"
                                   Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding SummaryText}" FontSize="12"
                               Foreground="{DynamicResource AppSecondaryTextBrush}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Content="⟳ Refresh" Command="{Binding RefreshCommand}" />
                    <CheckBox Content="Auto" IsChecked="{Binding AutoRefresh}" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom" Padding="14,6"
                Background="{DynamicResource AppChromeBrush}"
                BorderBrush="{DynamicResource AppDividerBrush}" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding StatusText}" FontSize="11"
                           Foreground="{DynamicResource AppMutedTextBrush}" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Text="open" FontSize="11" Foreground="{DynamicResource AppMutedTextBrush}" />
                    <TextBlock Text="{Binding UptimeText}" FontSize="11"
                               Foreground="{DynamicResource AppSecondaryTextBrush}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Aggregate latency graph -->
        <Border DockPanel.Dock="Top" Margin="14,12,14,6" Padding="12"
                Background="{DynamicResource AppInsetBrush}"
                BorderBrush="{DynamicResource AppDividerBrush}" BorderThickness="1" CornerRadius="8">
            <StackPanel Spacing="8">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Average latency"
                               Foreground="{DynamicResource AppMutedTextBrush}" FontSize="11" FontWeight="Bold" />
                    <TextBlock Grid.Column="1" Text="{Binding AverageLatencyText}"
                               Foreground="{DynamicResource AppTextBrush}" FontWeight="Bold" FontSize="13" />
                </Grid>
                <ctl:Sparkline Values="{Binding AggregateHistory}" Height="72"
                               Stroke="#4C8BF5" StrokeThickness="1.8" Fill="#224C8BF5" />
            </StackPanel>
        </Border>

        <!-- Per-connection list -->
        <ScrollViewer>
            <StackPanel Margin="14,6,14,12" Spacing="8">

                <TextBlock Text="No networked connections in this workspace."
                           IsVisible="{Binding !HasConnections}"
                           Foreground="{DynamicResource AppMutedTextBrush}" FontSize="13" Margin="2,10" />

                <ItemsControl ItemsSource="{Binding Connections}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ConnectionStatRow">
                            <Border Background="{DynamicResource AppInsetBrush}"
                                    BorderBrush="{DynamicResource AppDividerBrush}" BorderThickness="1"
                                    CornerRadius="8" Padding="12" Margin="0,0,0,2">
                                <StackPanel Spacing="8">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <TextBlock Grid.Column="0" Text="{Binding Glyph}" FontSize="15"
                                                   VerticalAlignment="Center" Margin="0,0,10,0" />
                                        <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AppTextBrush}" />
                                            <TextBlock Text="{Binding Endpoint}" FontSize="11"
                                                       FontFamily="Menlo,Consolas,monospace"
                                                       Foreground="{DynamicResource AppSecondaryTextBrush}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Spacing="1" HorizontalAlignment="Right"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding LatencyText}" FontWeight="Bold" FontSize="14"
                                                       HorizontalAlignment="Right"
                                                       Foreground="{DynamicResource AppTextBrush}" />
                                            <TextBlock Text="{Binding StatusText}" FontSize="11"
                                                       HorizontalAlignment="Right"
                                                       Foreground="{Binding StatusBrush}" />
                                        </StackPanel>
                                    </Grid>
                                    <ctl:Sparkline Values="{Binding History}" Height="40"
                                                   Stroke="{Binding LineBrush}" StrokeThickness="1.4" />
                                    <TextBlock Text="{Binding RangeText}" FontSize="11"
                                               Foreground="{DynamicResource AppMutedTextBrush}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RemoteStuff.ViewModels"
        x:Class="RemoteStuff.Views.DeveloperWindow"
        x:DataType="vm:DeveloperViewModel"
        Width="760" Height="620"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppSurfaceBrush}"
        Title="Developer Tools">

    <DockPanel Margin="0">

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Padding="12,8"
                Background="{DynamicResource AppChromeBrush}"
                BorderBrush="{DynamicResource AppDividerBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="🛠 Diagnostics" FontWeight="Bold" FontSize="14"
                           Foreground="#EEE" VerticalAlignment="Center" />
                <Button Content="⟳ Refresh" Command="{Binding RefreshCommand}" />
                <Button Content="📋 Copy" Command="{Binding CopyCommand}" />
                <CheckBox Content="Auto-refresh" IsChecked="{Binding AutoRefresh}"
                          VerticalAlignment="Center" />
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"
                           Foreground="{DynamicResource AppMutedTextBrush}" />
            </StackPanel>
        </Border>

        <!-- Report -->
        <ScrollViewer>
            <TextBox Text="{Binding Report}" IsReadOnly="True"
                     FontFamily="Menlo,Consolas,monospace" FontSize="12"
                     AcceptsReturn="True" TextWrapping="NoWrap"
                     Background="Transparent" BorderThickness="0"
                     Padding="14" />
        </ScrollViewer>
    </DockPanel>
</Window>
